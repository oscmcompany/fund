#!/usr/bin/env bash
# provision-common-vm -- shared provisioning logic for fund VMs
#
# This file must be sourced by provision-application-vm or provision-trainer-vm.
# It must not be executed directly.
#
# Callers must set before sourcing:
#   VM_ROLE    -- "application" or "trainer"
#   PRODUCTION -- true or false

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && {
  echo "Error: provision-common-vm must be sourced, not executed directly." >&2
  echo "Use tools/provision-application-vm or tools/provision-trainer-vm instead." >&2
  exit 1
}

# --------------------------------------------------------------------------- #
# Variables (populated by phase functions)
# --------------------------------------------------------------------------- #

VM_NAME=""
SECRETSPEC_PROFILE=""
AWS_ACCESS_KEY=""
AWS_SECRET_KEY=""
AWS_REGION=""
VM_BRANCH=""
VM_TAG=""
VM_EXTRA_TAG=""

# --------------------------------------------------------------------------- #
# Helpers
# --------------------------------------------------------------------------- #

step() {
  echo ""
  echo "==> $1"
}

fail() {
  echo "ERROR: $1" >&2
  exit 1
}

prompt() {
  local message="$1"
  local default="${2:-}"
  local result
  if [[ -n "$default" ]]; then
    printf "%s [%s]: " "$message" "$default" >&2
  else
    printf "%s: " "$message" >&2
  fi
  read -r result
  echo "${result:-$default}"
}

confirm() {
  local message="$1"
  local answer
  printf "%s [Y/n]: " "$message"
  read -r answer
  case "${answer:-Y}" in
    [Yy]*) return 0 ;;
    *) return 1 ;;
  esac
}

remote() {
  ssh -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new "$VM_NAME.exe.xyz" "$@"
}

remote_tty() {
  ssh -t -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new "$VM_NAME.exe.xyz" "$@"
}

remote_long() {
  ssh -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -o ServerAliveInterval=60 "$VM_NAME.exe.xyz" "$@"
}

remote_long_tty() {
  ssh -t -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -o ServerAliveInterval=60 "$VM_NAME.exe.xyz" "$@"
}

# Source Nix in a remote command chain
NIX_SOURCE='for p in /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh /etc/profile.d/nix.sh; do [ -f "$p" ] && . "$p" && break; done'

# --------------------------------------------------------------------------- #
# Phase 1: Collect configuration
# --------------------------------------------------------------------------- #

phase_collect() {
  step "Collecting configuration"

  # AWS credentials
  echo ""
  if [[ -f "$HOME/.aws/credentials" ]] && command -v aws &>/dev/null; then
    local current_key
    current_key="$(aws configure get aws_access_key_id 2>/dev/null || true)"
    if [[ -n "$current_key" ]]; then
      echo "Found local AWS credentials (access key: ${current_key:0:8}...)"
      if confirm "Use these credentials for the VM?"; then
        AWS_ACCESS_KEY="$(aws configure get aws_access_key_id)"
        AWS_SECRET_KEY="$(aws configure get aws_secret_access_key)"
        AWS_REGION="$(aws configure get region 2>/dev/null || echo "us-east-1")"
      fi
    fi
  fi

  if [[ -z "$AWS_ACCESS_KEY" ]]; then
    echo "Enter AWS credentials for the VM:"
    AWS_ACCESS_KEY="$(prompt "  Access Key ID")"
    read -r -s -p "  Secret Access Key: " AWS_SECRET_KEY
    echo ""
    AWS_REGION="$(prompt "  Region" "us-east-1")"
  fi

  [[ -z "$AWS_ACCESS_KEY" ]] && fail "AWS Access Key ID is required"
  [[ -z "$AWS_SECRET_KEY" ]] && fail "AWS Secret Access Key is required"

  # Secretspec profile and VM name
  echo ""
  local slug default_name
  slug="$(head -c 4 /dev/urandom | xxd -p)"
  default_name="oscm-fund-${VM_ROLE}-${slug}"

  if [[ "$PRODUCTION" == true ]]; then
    VM_TAG="production"
    SECRETSPEC_PROFILE="production"
  else
    VM_TAG="development"
    echo "Known profiles: development/john.forstmeier, development/chris.addy"
    SECRETSPEC_PROFILE="$(prompt "Secretspec profile" "development")"
    echo ""
    VM_EXTRA_TAG="$(prompt "Extra tag (optional, e.g. john or feature-x)" "")"
  fi

  echo ""
  VM_NAME="$(prompt "VM name" "$default_name")"

  # Branch
  echo ""
  VM_BRANCH="$(prompt "Branch" "master")"

  # Summary
  echo ""
  echo "--- Configuration Summary ---"
  echo "  VM name:    $VM_NAME"
  echo "  Role:       $VM_ROLE"
  if [[ -n "$VM_EXTRA_TAG" ]]; then
    echo "  Tags:       #${VM_TAG} #${VM_EXTRA_TAG}"
  else
    echo "  Tag:        #${VM_TAG}"
  fi
  echo "  Profile:    $SECRETSPEC_PROFILE"
  echo "  AWS key:    ${AWS_ACCESS_KEY:0:8}..."
  echo "  AWS region: $AWS_REGION"
  echo "  Branch:     $VM_BRANCH"
  echo "-----------------------------"
  echo ""

  if ! confirm "Proceed with this configuration?"; then
    echo "Aborted."
    exit 0
  fi
}

# --------------------------------------------------------------------------- #
# Phase 2: Create and tag VM
# --------------------------------------------------------------------------- #

phase_create_vm() {
  step "Creating exe.dev VM"

  local vm_exists=false
  local vm_list
  vm_list="$(ssh exe.dev ls --json 2>/dev/null || echo '{"vms":[]}')"
  if echo "$vm_list" | jq -e ".vms[] | select(.vm_name == \"$VM_NAME\")" &>/dev/null; then
    local vm_status
    vm_status="$(echo "$vm_list" | jq -r ".vms[] | select(.vm_name == \"$VM_NAME\") | .status")"
    echo "VM '$VM_NAME' already exists (status: $vm_status)"
    vm_exists=true
  fi

  if [[ "$vm_exists" == false ]]; then
    echo "Creating VM '$VM_NAME'..."
    ssh exe.dev new --name="$VM_NAME"
    echo "VM creation initiated"
  fi

  # Poll until running
  local elapsed=0
  local timeout=300
  while [[ $elapsed -lt $timeout ]]; do
    local status
    status="$(ssh exe.dev ls --json 2>/dev/null | jq -r ".vms[] | select(.vm_name == \"$VM_NAME\") | .status" || echo "unknown")"
    if [[ "$status" == "running" ]]; then
      echo "VM '$VM_NAME' is running"
      break
    fi
    echo "  Status: $status (waiting...)"
    sleep 3
    elapsed=$((elapsed + 3))
  done
  [[ $elapsed -ge $timeout ]] && fail "Timed out waiting for VM to reach running state after ${timeout}s"

  # Wait for SSH connectivity
  step "Waiting for SSH connectivity"
  local ssh_elapsed=0
  local ssh_timeout=60
  while [[ $ssh_elapsed -lt $ssh_timeout ]]; do
    if ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new "$VM_NAME.exe.xyz" true 2>/dev/null; then
      echo "SSH connection established"
      break
    fi
    sleep 3
    ssh_elapsed=$((ssh_elapsed + 3))
  done
  [[ $ssh_elapsed -ge $ssh_timeout ]] && fail "Timed out waiting for SSH connectivity after ${ssh_timeout}s"

  # Apply tag(s)
  step "Tagging VM"
  if [[ -n "$VM_EXTRA_TAG" ]]; then
    ssh exe.dev tag "$VM_NAME" "$VM_TAG" "$VM_EXTRA_TAG" || true
    echo "Applied tags: #${VM_TAG} #${VM_EXTRA_TAG}"
  else
    ssh exe.dev tag "$VM_NAME" "$VM_TAG" || true
    echo "Applied tag: #${VM_TAG}"
  fi
}

# --------------------------------------------------------------------------- #
# Phase 3: Bootstrap
# --------------------------------------------------------------------------- #

phase_bootstrap() {
  step "Configuring AWS credentials on VM"
  remote "mkdir -p ~/.aws"
  printf '[default]\naws_access_key_id = %s\naws_secret_access_key = %s\n' \
    "$AWS_ACCESS_KEY" "$AWS_SECRET_KEY" \
    | remote "cat > ~/.aws/credentials"
  printf '[default]\nregion = %s\noutput = json\n' \
    "$AWS_REGION" \
    | remote "cat > ~/.aws/config"
  remote "chmod 600 ~/.aws/credentials ~/.aws/config"
  echo "Credentials written to VM"

  step "Cloning repository on VM"
  if remote "test -d ~/fund/.git" 2>/dev/null; then
    echo "Repository already cloned, fetching latest..."
    remote "cd ~/fund && git fetch --all --prune"
  else
    echo "Cloning oscmcompany/fund..."
    remote "git clone https://github.com/oscmcompany/fund.git ~/fund"
  fi
  local quoted_branch
  printf -v quoted_branch '%q' "$VM_BRANCH"
  remote "cd ~/fund && git checkout -B $quoted_branch origin/$quoted_branch"
  echo "Repository ready (branch: $VM_BRANCH)"

  step "Running bootstrap-machine on VM (this will take a while)"
  local bootstrap_args="--profile $SECRETSPEC_PROFILE --noninteractive"
  if [[ "$PRODUCTION" == true ]]; then
    bootstrap_args="--production $bootstrap_args"
  fi
  # shellcheck disable=SC2086
  remote_long_tty "cd ~/fund && bash tools/bootstrap-machine $bootstrap_args" \
    || fail "bootstrap-machine failed"
  echo "Bootstrap complete"
}

# --------------------------------------------------------------------------- #
# Phase 4: Reboot
# --------------------------------------------------------------------------- #

phase_reboot() {
  step "Rebooting VM"
  local old_boot_id
  old_boot_id="$(remote "cat /proc/sys/kernel/random/boot_id" 2>/dev/null || true)"
  remote "sudo reboot" || true
  sleep 5

  local reboot_elapsed=0
  local reboot_timeout=60
  while [[ $reboot_elapsed -lt $reboot_timeout ]]; do
    local new_boot_id
    if new_boot_id="$(ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new "$VM_NAME.exe.xyz" \
      "cat /proc/sys/kernel/random/boot_id" 2>/dev/null)" \
      && [[ -z "$old_boot_id" || "$new_boot_id" != "$old_boot_id" ]]; then
      echo "VM back up after reboot"
      return 0
    fi
    sleep 3
    reboot_elapsed=$((reboot_elapsed + 3))
  done
  fail "Timed out waiting for VM to come back after reboot (${reboot_timeout}s)"
}

# --------------------------------------------------------------------------- #
# Share VM with team
# --------------------------------------------------------------------------- #

phase_share_vm() {
  step "Sharing VM with team"
  ssh exe.dev share add "$VM_NAME" team 2>/dev/null \
    && echo "Shared $VM_NAME with team" \
    || echo "Warning: could not share VM with team (run: ssh exe.dev share add $VM_NAME team)"
  ssh exe.dev share access allow "$VM_NAME" 2>/dev/null \
    && echo "Enabled team SSH access" \
    || echo "Warning: could not enable team access (run: ssh exe.dev share access allow $VM_NAME)"
}
