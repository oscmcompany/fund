#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PID_FILE="/tmp/git-sync.pid"
POLL_INTERVAL=60
RESTART_FLAG="/tmp/git-sync-restart"

log() {
  echo "$(date -u +"%Y-%m-%dT%H:%M:%SZ") $1"
}

# Resolve poll log path. Called after .env is sourced so FUND_LOG_DIR is available.
init_poll_log() {
  local log_directory="${FUND_LOG_DIR:-/var/log/fund}"
  mkdir -p "$log_directory" 2>/dev/null || true
  if [[ ! -w "$log_directory" ]]; then
    log_directory="${HOME}/.local/state/fund/log"
    mkdir -p "$log_directory"
  fi
  POLL_LOG="$log_directory/git-sync-poll.log"
}

# Log a message to the poll log file (used by the poller subprocess).
log_poll() {
  echo "$(date -u +"%Y-%m-%dT%H:%M:%SZ") $1" >> "$POLL_LOG" 2>&1
}

# ------------------------------------------------------------------ #
# Clean up stale processes on service ports before starting
# ------------------------------------------------------------------ #
kill_port_holders() {
  for port in 8080 8082 8083 8084; do
    local pids
    pids="$(lsof -ti :"$port" 2>/dev/null || true)"
    if [[ -n "$pids" ]]; then
      log "Killing stale processes on port $port: $pids"
      echo "$pids" | xargs kill -9 2>/dev/null || true
    fi
  done
}

# ------------------------------------------------------------------ #
# Subcommand: poll (runs as background process, logs to file)
# ------------------------------------------------------------------ #
run_poll() {
  init_poll_log
  log_poll "Poller started (PID $$)"

  while true; do
    sleep "$POLL_INTERVAL"

    cd "$REPO_ROOT"

    if ! git fetch origin master >> "$POLL_LOG" 2>&1; then
      log_poll "git fetch failed, will retry next cycle"
      continue
    fi

    local_head="$(git rev-parse HEAD)"
    remote_head="$(git rev-parse origin/master)"

    if [[ "$local_head" != "$remote_head" ]]; then
      log_poll "New commits detected (local=$local_head remote=$remote_head)"
      touch "$RESTART_FLAG"

      # Kill process-compose (the process manager spawned by devenv) which
      # will in turn terminate all managed services. Also kill any devenv
      # process. This is more reliable than chasing PIDs through the tree.
      if pkill -TERM -u "$USER" -f "process-compose" 2>/dev/null; then
        log_poll "Sent SIGTERM to process-compose"
      else
        log_poll "WARNING: process-compose not found"
      fi
      if pkill -TERM -u "$USER" -f "devenv.*--profile application" 2>/dev/null; then
        log_poll "Sent SIGTERM to devenv"
      else
        log_poll "WARNING: devenv process not found"
      fi
    fi
  done
}

# ------------------------------------------------------------------ #
# Subcommand: up (runs devenv foreground in primary tmux pane)
# ------------------------------------------------------------------ #
run_up() {
  # PID file guard -- prevent duplicate instances
  if [[ -f "$PID_FILE" ]]; then
    existing_pid="$(cat "$PID_FILE")"
    if kill -0 "$existing_pid" 2>/dev/null; then
      echo "git-sync is already running (PID $existing_pid)"
      exit 1
    fi
    log "Removing stale PID file (PID $existing_pid no longer running)"
    rm -f "$PID_FILE"
  fi
  echo $$ > "$PID_FILE"

  POLL_PID=""
  cleanup() {
    log "Received shutdown signal, cleaning up"
    # Kill the background poller process
    [[ -n "$POLL_PID" ]] && kill "$POLL_PID" 2>/dev/null || true
    # Kill devenv and process-compose (scoped to current user)
    pkill -TERM -u "$USER" -f "process-compose" 2>/dev/null || true
    pkill -TERM -u "$USER" -f "devenv.*--profile application" 2>/dev/null || true
    rm -f "$PID_FILE" "$RESTART_FLAG"
    log "Shutdown complete"
    exit 0
  }
  trap cleanup SIGTERM SIGINT

  cd "$REPO_ROOT"

  # Source .env so FUND_PROFILE is set during Nix evaluation
  if [[ -f "$REPO_ROOT/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$REPO_ROOT/.env"
    set +a
    log "Loaded .env (FUND_PROFILE=${FUND_PROFILE:-<unset>})"
  else
    log "WARNING: no .env found, FUND_PROFILE will be empty"
  fi

  init_poll_log
  log "git-sync starting in $REPO_ROOT"

  rm -f "$RESTART_FLAG"
  bash "$SCRIPT_DIR/git-sync" poll &
  POLL_PID=$!

  # Main loop: run devenv foreground, restart when poller signals
  while true; do
    kill_port_holders
    log "Starting devenv --profile application up"
    # Run devenv in the foreground so the process-compose TUI renders in
    # the tmux pane. The poller terminates it by name (see run_poll).
    devenv --profile application up || true

    # If the restart flag is set, the poller pulled new code
    if [[ -f "$RESTART_FLAG" ]]; then
      rm -f "$RESTART_FLAG"
      log "Resetting to origin/master"
      git reset --hard origin/master
      devenv allow 2>/dev/null || log "WARNING: devenv allow failed; manual 'devenv allow' may be needed"
      log "Restarting with updated code ($(git rev-parse --short HEAD))"
      continue
    fi

    # devenv exited without a restart flag -- unexpected exit, restart after delay
    log "devenv exited unexpectedly, restarting in 5s"
    sleep 5
  done
}

# ------------------------------------------------------------------ #
# Dispatch subcommand
# ------------------------------------------------------------------ #
case "${1:-up}" in
  up)   run_up ;;
  poll) run_poll ;;
  *)    echo "Usage: git-sync [up|poll]" >&2; exit 1 ;;
esac
