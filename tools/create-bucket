#!/usr/bin/env bash
set -euo pipefail

PROFILE="${1:-}"
if [[ -z "$PROFILE" ]]; then
  echo "Usage: $(basename "$0") <profile>"
  echo "  e.g. $(basename "$0") development/chris.addy"
  echo "  e.g. $(basename "$0") production"
  exit 1
fi

SLUG="${PROFILE//[\/.]/-}"
BUCKET="oscm-fund-${SLUG}"

echo "Ensuring bucket $BUCKET exists"
if output=$(aws s3api create-bucket --bucket "$BUCKET" --region us-east-1 2>&1); then
  echo "Created bucket $BUCKET"
elif echo "$output" | grep -q "BucketAlreadyOwnedByYou"; then
  echo "Bucket $BUCKET already exists, skipping"
else
  echo "Error creating bucket $BUCKET: $output" >&2
  exit 1
fi

echo "S3 bucket ready: $BUCKET"
