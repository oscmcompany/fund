#!/usr/bin/env bash
set -euo pipefail

# --------------------------------------------------------------------------- #
# setup-dashboard-ssh -- Configure SSH access for the dashboard_service TUI
#
# Runs a dedicated sshd instance on port 2222 so that external users can
# connect with: ssh -p 2222 dashboard@<vm>.exe.xyz
# and be dropped directly into the read-only TUI with no shell access.
#
# A separate sshd is required because exe.dev manages the primary sshd on
# port 22 and does not allow custom sshd_config modifications.
#
# Run on the application VM after bootstrap and dashboard_service binary
# installation are complete:
#
#   bash tools/setup-dashboard-ssh
#
# Idempotent: safe to re-run.
# --------------------------------------------------------------------------- #

DASHBOARD_USER="dashboard"
DASHBOARD_BINARY="/home/exedev/.local/bin/dashboard_service"
DASHBOARD_SSH_DIR="/etc/dashboard-ssh"
DASHBOARD_SSH_PORT=2222

step() {
  echo ""
  echo "==> $1"
}

# --------------------------------------------------------------------------- #
# 1. Verify dashboard_service binary exists
# --------------------------------------------------------------------------- #
step "Checking dashboard_service binary"

if [[ ! -x "$DASHBOARD_BINARY" ]]; then
  echo "Error: $DASHBOARD_BINARY not found or not executable."
  echo "Run bootstrap-machine with --production first."
  exit 1
fi
echo "Found $DASHBOARD_BINARY"

# --------------------------------------------------------------------------- #
# 2. Create the dashboard OS user
# --------------------------------------------------------------------------- #
step "Creating '$DASHBOARD_USER' OS user"

if id "$DASHBOARD_USER" &>/dev/null; then
  echo "User '$DASHBOARD_USER' already exists"
else
  sudo useradd \
    --system \
    --shell /usr/sbin/nologin \
    --create-home \
    --home-dir "/home/$DASHBOARD_USER" \
    "$DASHBOARD_USER"
  echo "Created user '$DASHBOARD_USER'"
fi

# --------------------------------------------------------------------------- #
# 3. Install the accept-all-keys script
# --------------------------------------------------------------------------- #
step "Installing AuthorizedKeysCommand script"

ACCEPT_ALL_KEYS="/usr/local/bin/dashboard-accept-all-keys"

sudo tee "$ACCEPT_ALL_KEYS" > /dev/null << 'SCRIPT'
#!/bin/sh
# Accept any SSH public key presented for the dashboard user.
# Arguments: username key-type base64-key (from sshd %u %t %k tokens).
printf '%s %s\n' "$2" "$3"
SCRIPT
sudo chmod 755 "$ACCEPT_ALL_KEYS"
echo "Installed $ACCEPT_ALL_KEYS"

# --------------------------------------------------------------------------- #
# 4. Write the dashboard .env with DATABASE_URL from secretspec
# --------------------------------------------------------------------------- #
step "Writing /home/$DASHBOARD_USER/.env"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Source Nix so devenv and secretspec are on PATH.
# Temporarily relax nounset — Nix profile scripts may reference unbound variables.
set +u
for profile in /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh \
               /etc/profile.d/nix.sh; do
  if [[ -f "$profile" ]]; then
    # shellcheck disable=SC1090
    . "$profile"
    break
  fi
done
set -u

DATABASE_URL="$(cd "$REPO_ROOT" && devenv shell -- secretspec run --profile dashboard -- printenv DATABASE_URL 2>/dev/null)" \
  || true

if [[ -z "$DATABASE_URL" ]]; then
  echo "Error: Could not retrieve DATABASE_URL from secretspec (profile: dashboard)."
  echo "  Ensure the secret exists: secretspec set --profile dashboard DATABASE_URL"
  exit 1
fi

# Single-quote the value to prevent shell expansion when the launcher sources it.
printf "DATABASE_URL='%s'\n" "$DATABASE_URL" | sudo tee "/home/$DASHBOARD_USER/.env" > /dev/null
sudo chown "root:$DASHBOARD_USER" "/home/$DASHBOARD_USER/.env"
sudo chmod 640 "/home/$DASHBOARD_USER/.env"
echo "Wrote DATABASE_URL to /home/$DASHBOARD_USER/.env"

# --------------------------------------------------------------------------- #
# 5. Create a wrapper that loads .env and runs dashboard_service
# --------------------------------------------------------------------------- #
step "Installing dashboard launcher"

LAUNCHER="/usr/local/bin/dashboard-launcher"

sudo tee "$LAUNCHER" > /dev/null << EOF
#!/bin/sh
set -e
if [ -f /home/$DASHBOARD_USER/.env ]; then
  set -a
  . /home/$DASHBOARD_USER/.env
  set +a
fi
exec "$DASHBOARD_BINARY"
EOF
sudo chmod 755 "$LAUNCHER"
echo "Installed $LAUNCHER"

# --------------------------------------------------------------------------- #
# 6. Generate host keys and write sshd_config for the dashboard sshd
# --------------------------------------------------------------------------- #
step "Configuring dedicated dashboard sshd on port $DASHBOARD_SSH_PORT"

sudo mkdir -p "$DASHBOARD_SSH_DIR"

# Generate a host key if one does not exist
if [[ ! -f "$DASHBOARD_SSH_DIR/ssh_host_ed25519_key" ]]; then
  sudo ssh-keygen -t ed25519 -f "$DASHBOARD_SSH_DIR/ssh_host_ed25519_key" -N "" -q
  echo "Generated host key"
else
  echo "Host key already exists"
fi

sudo tee "$DASHBOARD_SSH_DIR/sshd_config" > /dev/null << EOF
# Dashboard-only sshd — accepts any key, drops users into the TUI
Port $DASHBOARD_SSH_PORT
HostKey $DASHBOARD_SSH_DIR/ssh_host_ed25519_key
HostKeyAlgorithms ssh-ed25519

# Only the dashboard user may connect
AllowUsers $DASHBOARD_USER

# Accept any public key via the accept-all-keys helper
PubkeyAuthentication yes
AuthorizedKeysCommand $ACCEPT_ALL_KEYS %u %t %k
AuthorizedKeysCommandUser nobody
AuthorizedKeysFile none

# Force the TUI launcher — no shell access
ForceCommand $LAUNCHER

# Disable everything else
PasswordAuthentication no
PermitRootLogin no
AllowTcpForwarding no
X11Forwarding no
PermitTunnel no
AllowAgentForwarding no
ClientAliveInterval 30
ClientAliveCountMax 3

# Logging
SyslogFacility AUTH
LogLevel INFO
EOF
echo "Wrote $DASHBOARD_SSH_DIR/sshd_config"

# --------------------------------------------------------------------------- #
# 7. Validate the config
# --------------------------------------------------------------------------- #
step "Validating dashboard sshd config"

if ! sudo /usr/sbin/sshd -t -f "$DASHBOARD_SSH_DIR/sshd_config" 2>&1; then
  # Fall back to exe.dev sshd binary if system sshd is not available
  if [[ -x /exe.dev/bin/sshd ]]; then
    sudo /exe.dev/bin/sshd -t -f "$DASHBOARD_SSH_DIR/sshd_config" 2>&1 || {
      echo "ERROR: sshd configuration test failed."
      exit 1
    }
  else
    echo "ERROR: sshd configuration test failed."
    exit 1
  fi
fi
echo "Config validation passed"

# --------------------------------------------------------------------------- #
# 8. Install and start systemd service
# --------------------------------------------------------------------------- #
step "Installing dashboard-sshd systemd service"

sudo tee /etc/systemd/system/dashboard-sshd.service > /dev/null << EOF
[Unit]
Description=Dashboard SSH server (port $DASHBOARD_SSH_PORT)
After=network.target

[Service]
ExecStart=/usr/sbin/sshd -D -f $DASHBOARD_SSH_DIR/sshd_config
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

# If /usr/sbin/sshd does not exist, try the exe.dev binary
if [[ ! -x /usr/sbin/sshd ]] && [[ -x /exe.dev/bin/sshd ]]; then
  sudo sed -i "s|/usr/sbin/sshd|/exe.dev/bin/sshd|" /etc/systemd/system/dashboard-sshd.service
fi

sudo systemctl daemon-reload
sudo systemctl enable dashboard-sshd
sudo systemctl restart dashboard-sshd
echo "dashboard-sshd service started"

# --------------------------------------------------------------------------- #
# Done
# --------------------------------------------------------------------------- #
step "Dashboard SSH access configured"

echo ""
echo "External users can now connect with:"
echo "  ssh -p $DASHBOARD_SSH_PORT dashboard@$(hostname).exe.xyz"
echo ""
echo "To test locally:"
echo "  ssh -p $DASHBOARD_SSH_PORT dashboard@localhost"
echo ""
