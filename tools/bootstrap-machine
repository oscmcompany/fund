#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

PRODUCTION=false
NONINTERACTIVE=false
PROFILE=""
OS="$(uname -s)"

usage() {
  echo "Usage: $(basename "$0") --profile <name> [--production] [--noninteractive]"
  echo ""
  echo "Bootstrap a fresh machine for the fund development environment."
  echo ""
  echo "Options:"
  echo "  --profile <name>    Fund profile (e.g., development/chris.addy, production) [required]"
  echo "  --production        Configure production environment and validate secrets"
  echo "  --noninteractive    Skip the final exec \$SHELL (for use from automation)"
  echo "  -h, --help          Show this help message"
  exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile)
      if [[ $# -lt 2 || -z "${2:-}" ]]; then
        echo "Error: --profile requires a value"
        usage 1
      fi
      PROFILE="$2"
      shift 2
      ;;
    --production)
      PRODUCTION=true
      shift
      ;;
    --noninteractive)
      NONINTERACTIVE=true
      shift
      ;;
    -h|--help)
      usage
      ;;
    *)
      echo "Error: unknown option '$1'"
      usage 1
      ;;
  esac
done

if [[ -z "$PROFILE" ]]; then
  echo "Error: --profile is required (e.g., --profile development/chris.addy or --profile production)"
  usage 1
fi

step() {
  echo ""
  echo "==> $1"
}

ensure_nix_trusted_user() {
  local user
  user="$(whoami)"

  # Determinate Systems installer manages /etc/nix/nix.conf as read-only;
  # custom settings must go in /etc/nix/nix.custom.conf.
  # Fall back to /etc/nix/nix.conf for traditional Nix installs.
  local custom_conf="/etc/nix/nix.custom.conf"
  local nix_conf="/etc/nix/nix.conf"

  # Check whether the user is already trusted in either config file
  for conf in "$custom_conf" "$nix_conf"; do
    if [[ -f "$conf" ]] && grep -qE "^trusted-users\s*=.*\b${user}\b" "$conf"; then
      return 0
    fi
  done

  echo "Adding $user to Nix trusted-users..."

  # Prefer nix.custom.conf (Determinate installer); fall back to nix.conf
  local target="$nix_conf"
  if [[ -L "$nix_conf" ]] || [[ -f "$custom_conf" ]]; then
    target="$custom_conf"
  fi

  if [[ -f "$target" ]] && grep -qE "^trusted-users\s*=" "$target"; then
    sudo sed -i "s/^trusted-users\s*=.*/& $user/" "$target"
  else
    echo "trusted-users = root $user" | sudo tee -a "$target" >/dev/null
  fi

  sudo systemctl restart nix-daemon 2>/dev/null || true
}

# --------------------------------------------------------------------------- #
# Ensure Nix paths are available in this shell session
# --------------------------------------------------------------------------- #
for profile in /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh \
               /etc/profile.d/nix.sh; do
  if [[ -f "$profile" ]]; then
    # shellcheck disable=SC1090
    . "$profile"
    break
  fi
done

# --------------------------------------------------------------------------- #
# 1. Install Nix via Determinate Systems installer
# --------------------------------------------------------------------------- #
step "Checking Nix installation"

if command -v nix &>/dev/null; then
  echo "Nix is already installed"
  ensure_nix_trusted_user
else
  echo "Installing Nix via Determinate Systems installer..."
  curl --proto '=https' --tlsv1.2 -sSf -L \
    https://install.determinate.systems/nix | sh -s -- install --no-confirm

  # Source the Nix daemon profile so the current shell can use nix immediately
  for profile in /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh \
                 /etc/profile.d/nix.sh; do
    if [[ -f "$profile" ]]; then
      # shellcheck disable=SC1090
      . "$profile"
      break
    fi
  done

  if ! command -v nix &>/dev/null; then
    echo "Error: nix not found on PATH after installation"
    exit 1
  fi

  ensure_nix_trusted_user

  echo "Nix installed successfully"
fi

# --------------------------------------------------------------------------- #
# 2. Install devenv
# --------------------------------------------------------------------------- #
step "Checking devenv installation"

if command -v devenv &>/dev/null; then
  echo "devenv is already installed, skipping"
else
  echo "Installing devenv..."
  nix profile add nixpkgs#devenv
  echo "devenv installed successfully"
fi

# --------------------------------------------------------------------------- #
# 2b. Install tmux (required for production service sessions)
# --------------------------------------------------------------------------- #
if ! command -v tmux &>/dev/null; then
  echo "Installing tmux..."
  sudo apt-get install -y -qq tmux 2>/dev/null || nix profile add nixpkgs#tmux
  echo "tmux installed"
fi

# --------------------------------------------------------------------------- #
# 3. Configure devenv shell hook (auto-activates environment on cd)
# --------------------------------------------------------------------------- #
step "Configuring devenv shell hook"

if ! grep -qF 'devenv hook' "$HOME/.bashrc" 2>/dev/null; then
  echo 'eval "$(devenv hook bash)"' >> "$HOME/.bashrc"
  echo "Added devenv hook to ~/.bashrc"
else
  echo "devenv hook already in ~/.bashrc"
fi

# --------------------------------------------------------------------------- #
# 4. Install secretspec (secrets management for devenv services)
# --------------------------------------------------------------------------- #
step "Checking secretspec installation"

if command -v secretspec &>/dev/null; then
  echo "secretspec is already installed, skipping"
else
  echo "Installing secretspec..."
  nix profile add nixpkgs#secretspec
  echo "secretspec installed successfully"
fi

# --------------------------------------------------------------------------- #
# 5. Install AWS CLI (needed before devenv shell for secretspec)
# --------------------------------------------------------------------------- #
step "Checking AWS CLI installation"

if command -v aws &>/dev/null; then
  echo "AWS CLI is already installed, skipping"
else
  echo "Installing AWS CLI (required for secretspec)..."
  case "$OS" in
    Linux)
      curl -sSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip
      unzip -qo /tmp/awscliv2.zip -d /tmp
      sudo /tmp/aws/install
      rm -rf /tmp/awscliv2.zip /tmp/aws
      ;;
    Darwin)
      if command -v brew &>/dev/null; then
        brew install awscli
      else
        echo "Error: Homebrew not found. Install it from https://brew.sh"
        exit 1
      fi
      ;;
    *)
      echo "Error: unsupported OS '$OS' for AWS CLI install"
      exit 1
      ;;
  esac
  echo "AWS CLI installed successfully"
fi

# --------------------------------------------------------------------------- #
# 6. Configure AWS credentials (required for secretspec provider)
# --------------------------------------------------------------------------- #
step "Checking AWS credentials"

if aws sts get-caller-identity &>/dev/null; then
  IDENTITY=$(aws sts get-caller-identity --output text --query 'Arn')
  echo "Authenticated as: $IDENTITY"
else
  echo "AWS credentials are not configured."
  echo "devenv uses secretspec with the awssm provider, so valid"
  echo "credentials are required before the environment can build."
  echo ""
  aws configure
  echo ""

  if ! aws sts get-caller-identity &>/dev/null; then
    echo "Error: AWS credentials still not valid after configuration."
    echo "Re-run: $(basename "$0")"
    exit 1
  fi
  IDENTITY=$(aws sts get-caller-identity --output text --query 'Arn')
  echo "Authenticated as: $IDENTITY"
fi

# --------------------------------------------------------------------------- #
# 6b. Validate secretspec profile is defined
# --------------------------------------------------------------------------- #
if [[ "$PROFILE" != "production" ]]; then
  if ! grep -qF "[profiles.\"${PROFILE}\"]" "$REPO_ROOT/secretspec.toml"; then
    echo "Error: Profile '${PROFILE}' is not defined in secretspec.toml."
    echo "  Add a [profiles.\"${PROFILE}\"] section to secretspec.toml, commit it,"
    echo "  then re-run bootstrap."
    exit 1
  fi
fi

# --------------------------------------------------------------------------- #
# 7. Generate .env from .env.example
# --------------------------------------------------------------------------- #
DOTENV="$REPO_ROOT/.env"

if [[ ! -f "$DOTENV" ]]; then
  step "Creating .env (profile: $PROFILE)"
  sed "s|development/your.name|$PROFILE|g" "$REPO_ROOT/.env.example" > "$DOTENV"

  # Production needs extra vars
  if [[ "$PRODUCTION" == true ]]; then
    cat >> "$DOTENV" << 'EOF'
AWS_S3_MODEL_ARTIFACT_PATH=models/tide/
MASSIVE_BASE_URL=https://api.massive.com
EOF
  fi

  echo "Created $DOTENV"
else
  existing_profile=$(grep -E '^FUND_PROFILE=' "$DOTENV" | cut -d= -f2-)
  if [[ -n "$existing_profile" && "$existing_profile" != "$PROFILE" ]]; then
    echo "WARNING: .env has FUND_PROFILE=$existing_profile but --profile is $PROFILE"
    echo "  To update, delete .env and re-run, or edit it manually"
  fi
  echo ".env already exists, skipping creation"
fi

if [[ "$PRODUCTION" != true && "$PROFILE" != "production" ]]; then
  step "Ensuring dev S3 buckets exist"
  set -a
  # shellcheck disable=SC1090
  source "$DOTENV"
  set +a
  "$REPO_ROOT/tools/create-development-buckets" "${FUND_PROFILE:-$PROFILE}"
fi

# Patch devenv.yaml secretspec profile to match this environment
if [[ "$OS" == "Darwin" ]]; then
  sed -i '' "s|profile: .*|profile: $PROFILE|" "$REPO_ROOT/devenv.yaml"
else
  sed -i "s|profile: .*|profile: $PROFILE|" "$REPO_ROOT/devenv.yaml"
fi

cd "$REPO_ROOT"
devenv allow

# --------------------------------------------------------------------------- #
# 8. Create log directory
# --------------------------------------------------------------------------- #
step "Creating log directory"
sudo mkdir -p /var/log/fund
sudo chown "$(whoami)" /var/log/fund
echo "Created /var/log/fund"

# --------------------------------------------------------------------------- #
# 9. Build the devenv environment
# --------------------------------------------------------------------------- #
step "Building devenv environment"

cd "$REPO_ROOT"
echo "Running devenv shell to trigger Nix build (this may take a while)..."
devenv shell -- echo "devenv environment built successfully"

# --------------------------------------------------------------------------- #
# 10. Prod mode: validate secrets
# --------------------------------------------------------------------------- #
if [[ "$PRODUCTION" == true ]]; then
  echo "Validating secrets via secretspec..."
  devenv shell -- secretspec check || echo "Run 'secretspec set <KEY>' to populate missing secrets"
fi

# --------------------------------------------------------------------------- #
# Done
# --------------------------------------------------------------------------- #
step "Bootstrap complete"

echo ""
echo "Next steps:"
echo "  cd $REPO_ROOT"
if [[ "$PRODUCTION" == true ]]; then
  echo "  tmux new-session -d -s fund 'devenv --profile apps up'"
  echo "  tmux attach -t fund        # attach to services session"
else
  echo "  devenv shell        # enter the development environment"
  echo "  devenv --profile apps up  # start application services"
  echo ""
  echo "For production setup, re-run with:"
  echo "  $(basename "$0") --profile production --production"
fi

# Replace current shell so Nix paths are on PATH
if [[ "$NONINTERACTIVE" == false ]]; then
  exec "$SHELL" -l
fi
