#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

PROD=false
OS="$(uname -s)"

usage() {
  echo "Usage: $(basename "$0") [--prod]"
  echo ""
  echo "Bootstrap a fresh machine for the fund development environment."
  echo ""
  echo "Options:"
  echo "  --prod    Configure production environment variables and validate secrets"
  echo "  -h, --help  Show this help message"
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --prod)
      PROD=true
      shift
      ;;
    -h|--help)
      usage
      ;;
    *)
      echo "Error: unknown option '$1'"
      usage
      ;;
  esac
done

step() {
  echo ""
  echo "==> $1"
}

ensure_nix_trusted_user() {
  local nix_conf="/etc/nix/nix.conf"
  local user
  user="$(whoami)"
  if [[ -f "$nix_conf" ]] && ! grep -qE "^trusted-users\s*=.*\b${user}\b" "$nix_conf"; then
    echo "Adding $user to Nix trusted-users..."
    if grep -qE "^trusted-users\s*=" "$nix_conf"; then
      sudo sed -i "s/^trusted-users\s*=.*/& $user/" "$nix_conf"
    else
      echo "trusted-users = root $user" | sudo tee -a "$nix_conf" >/dev/null
    fi
    sudo systemctl restart nix-daemon 2>/dev/null || true
  fi
}

# --------------------------------------------------------------------------- #
# Ensure Nix paths are available in this shell session
# --------------------------------------------------------------------------- #
for profile in /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh \
               /etc/profile.d/nix.sh; do
  if [[ -f "$profile" ]]; then
    # shellcheck disable=SC1090
    . "$profile"
    break
  fi
done

# --------------------------------------------------------------------------- #
# 1. Install Nix via Determinate Systems installer
# --------------------------------------------------------------------------- #
step "Checking Nix installation"

if command -v nix &>/dev/null; then
  echo "Nix is already installed"
  ensure_nix_trusted_user
else
  echo "Installing Nix via Determinate Systems installer..."
  curl --proto '=https' --tlsv1.2 -sSf -L \
    https://install.determinate.systems/nix | sh -s -- install --no-confirm

  # Source the Nix daemon profile so the current shell can use nix immediately
  for profile in /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh \
                 /etc/profile.d/nix.sh; do
    if [[ -f "$profile" ]]; then
      # shellcheck disable=SC1090
      . "$profile"
      break
    fi
  done

  if ! command -v nix &>/dev/null; then
    echo "Error: nix not found on PATH after installation"
    exit 1
  fi

  ensure_nix_trusted_user

  echo "Nix installed successfully"
fi

# --------------------------------------------------------------------------- #
# 2. Install devenv
# --------------------------------------------------------------------------- #
step "Checking devenv installation"

if command -v devenv &>/dev/null; then
  echo "devenv is already installed, skipping"
else
  echo "Installing devenv..."
  nix profile install nixpkgs#devenv
  echo "devenv installed successfully"
fi

# --------------------------------------------------------------------------- #
# 3. Install AWS CLI (needed before devenv shell for secretspec)
# --------------------------------------------------------------------------- #
step "Checking AWS CLI installation"

if command -v aws &>/dev/null; then
  echo "AWS CLI is already installed, skipping"
else
  echo "Installing AWS CLI (required for secretspec)..."
  case "$OS" in
    Linux)
      sudo apt-get update -qq && sudo apt-get install -y -qq awscli
      ;;
    Darwin)
      if command -v brew &>/dev/null; then
        brew install awscli
      else
        echo "Error: Homebrew not found. Install it from https://brew.sh"
        exit 1
      fi
      ;;
    *)
      echo "Error: unsupported OS '$OS' for AWS CLI install"
      exit 1
      ;;
  esac
  echo "AWS CLI installed successfully"
fi

# --------------------------------------------------------------------------- #
# 4. Configure AWS credentials (required for secretspec provider)
# --------------------------------------------------------------------------- #
step "Checking AWS credentials"

if aws sts get-caller-identity &>/dev/null; then
  IDENTITY=$(aws sts get-caller-identity --output text --query 'Arn')
  echo "Authenticated as: $IDENTITY"
else
  echo "AWS credentials are not configured."
  echo "devenv uses secretspec with the awssm provider, so valid"
  echo "credentials are required before the environment can build."
  echo ""
  aws configure
  echo ""

  if ! aws sts get-caller-identity &>/dev/null; then
    echo "Error: AWS credentials still not valid after configuration."
    echo "Re-run: $(basename "$0")"
    exit 1
  fi
  IDENTITY=$(aws sts get-caller-identity --output text --query 'Arn')
  echo "Authenticated as: $IDENTITY"
fi

# --------------------------------------------------------------------------- #
# 5. Build the devenv environment
# --------------------------------------------------------------------------- #
step "Building devenv environment"

cd "$REPO_ROOT"
echo "Running devenv shell to trigger Nix build (this may take a while)..."
devenv shell -- echo "devenv environment built successfully"

# --------------------------------------------------------------------------- #
# 6. Prod mode: create .envrc and validate secrets
# --------------------------------------------------------------------------- #
if [[ "$PROD" == true ]]; then
  step "Configuring production environment"

  ENVRC="$REPO_ROOT/.envrc"
  if [[ ! -f "$ENVRC" ]]; then
    echo "Creating production .envrc..."
    cat > "$ENVRC" << 'ENVRC_EOF'
export FUND_ENVIRONMENT=production
export AWS_S3_DATA_BUCKET_NAME=fund-data-404221e2
export AWS_S3_MODEL_ARTIFACTS_BUCKET_NAME=fund-model-artifacts-404221e2
export AWS_S3_MODEL_ARTIFACT_PATH=artifacts/tide/
export MASSIVE_BASE_URL=https://api.massive.com
ENVRC_EOF
    echo "Created $ENVRC"
  else
    echo ".envrc already exists, skipping creation"
  fi

  echo "Validating secrets via secretspec..."
  devenv shell -- secretspec check || echo "Run 'secretspec set <KEY>' to populate missing secrets"
fi

# --------------------------------------------------------------------------- #
# Done
# --------------------------------------------------------------------------- #
step "Bootstrap complete"

echo ""
echo "Next steps:"
echo "  cd $REPO_ROOT"
echo "  devenv shell        # enter the development environment"
echo "  devenv --profile apps up  # start application services"
if [[ "$PROD" != true ]]; then
  echo ""
  echo "For production setup, re-run with:"
  echo "  $(basename "$0") --prod"
fi
